data/
*.db
*.sqlite
conversation_history.json
transcript.txt
record.md

# Exports (user-generated)
exports/
*.pdf

# Test files (not needed for users)
test_wasapi*.py

# Build artifacts
build/
dist/
*.egg-info/
*.spec

# OS files
.DS_Store
Thumbs.db

# Node (if any frontend)
node_modules/
