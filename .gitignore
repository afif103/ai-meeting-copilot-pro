# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
env/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.pytest_cache
.hypothesis
.mypy_cache

# Logs
*.log
pip-log.txt

# Environment & secrets (IMPORTANT - never commit!)
