# ==============================================
# AI Meeting Copilot Pro - Configuration
# ==============================================

# STEP 1: Get your free API keys from https://console.groq.com
# STEP 2: Replace the placeholder values below with your keys
# STEP 3: Save this file as ".env" (remove the .example part)

# Groq API Keys (you can use the same key for all 3, or different keys)
GROQ_API_KEY_REFINE=gsk_your_api_key_here
GROQ_API_KEY_QUICK=gsk_your_api_key_here
GROQ_API_KEY_SUGGEST=gsk_your_api_key_here

# LLM Settings (don't change unless you know what you're doing)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Whisper Settings
# Use "cuda" if you have NVIDIA GPU (faster)
# Use "cpu" if you don't have GPU (slower but works)
WHISPER_DEVICE=cpu
