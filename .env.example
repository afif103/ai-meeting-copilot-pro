# ==============================================
# AI Meeting Copilot Pro - Configuration
# ==============================================
#
# The app is LOCAL-FIRST: AI suggestions run on YOUR machine via Ollama.
# No API keys and no internet are required for the default setup.
#
# Setup: copy this file and rename the copy to ".env"
# (install.bat does this for you automatically)

# ----- LLM Provider -----
# "ollama" = local models via Ollama (default - free, private, offline)
# "groq"   = Groq cloud API (optional - requires API keys below)
LLM_PROVIDER=ollama

# ----- Ollama (Local AI) Settings -----
# 1. Install Ollama from https://ollama.com/download
# 2. Pull the models (one-time, in a terminal):
#      ollama pull qwen3:8b
#      ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_SUGGEST=qwen3:8b
OLLAMA_MODEL_REFINE=llama3.2:3b

# ----- Groq Cloud Settings (OPTIONAL) -----
# Only needed if you set LLM_PROVIDER=groq or switch to "Groq" inside the app.
# Get free keys at https://console.groq.com
# (you can use the same key for all 3 lines)
GROQ_API_KEY_REFINE=
GROQ_API_KEY_QUICK=
GROQ_API_KEY_SUGGEST=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ----- Whisper (Transcription) Settings -----
# Use "cuda" if you have an NVIDIA GPU (faster)
# Use "cpu" if you don't have a GPU (slower but works)
WHISPER_DEVICE=cpu
